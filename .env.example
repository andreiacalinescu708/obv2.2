# ==========================================
# CONFIGURARE MULTI-TENANT OPENBILL
# ==========================================

# Database Master (conține lista companiilor)
MASTER_DATABASE_URL=postgres://user:pass@host:5432/openbill_master

# Domeniul principal
MAIN_DOMAIN=openbill.ro

# Secret pentru sesiuni
SESSION_SECRET=schimba-asta-cu-o-cheie-lunga-si-aleatoare

# Email (Gmail)
EMAIL_FROM=support@openbill.ro
EMAIL_PASSWORD=your-app-password-here

# SuperAdmin default (se creează automat dacă nu există useri)
SUPERADMIN_USER=alex1
SUPERADMIN_PASS=change-this-password
SUPERADMIN_EMAIL=alex1@openbill.ro

# Pentru dezvoltare - creează automat compania FMD
AUTO_CREATE_FMD=false

# Node environment
NODE_ENV=production
